# PostgreSQL 접속 정보
DB_HOST=localhost
DB_NAME=
DB_USER=postgres
DB_PASSWORD=
DB_PORT=5432

# IR 파이프라인 vLLM 서버
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=
VLLM_TIMEOUT_SEC=360

# Simple 파이프라인 vLLM 서버
SIMPLE_VLLM_BASE_URL=http://localhost:8001
SIMPLE_VLLM_MODEL=
SIMPLE_VLLM_TIMEOUT_SEC=180

# Simple SQL Judge (LLM Judge 서버)
SIMPLE_SQL_JUDGE_BASE_URL=http://localhost:8000
SIMPLE_SQL_JUDGE_MODEL=

# 임베딩 서버 (TEI - Text Embeddings Inference)
TEI_BASE_URL=http://localhost:8080
TEI_TIMEOUT_SEC=60

# Cross-Encoder Reranker 로컬 모델 경로 (IR 파이프라인용, 선택)
RERANKER_MODEL_PATH=
